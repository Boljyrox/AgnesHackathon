# ---- Next.js BFF gateway environment (Module 4) ----

# Downstream FastAPI service (server-side only; never exposed to the browser).
FASTAPI_BASE_URL=http://localhost:8000

# JWT signing secrets — MUST match the FastAPI service (blueprint §7.3).
# Access tokens are verified at the edge (middleware); refresh tokens are
# verified by FastAPI only.
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Redis connection for the SSE pub/sub gateway.
REDIS_URL=redis://localhost:6379/0

# Set automatically by Next in production; controls the `Secure` cookie flag.
# NODE_ENV=production
