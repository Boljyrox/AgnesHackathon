# ============================================================================
#  Student Claw — BACKEND environment (.env)
#  Copy to `.env` and fill in.  `cp .env.example .env`
#
#  Secrets marked (SHARED) MUST be byte-for-byte identical to the frontend .env.
#  Generate any "openssl rand -hex 32" value with:  openssl rand -hex 32
# ============================================================================

# ── Database (PostgreSQL, async driver) ─────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://student_claw:student_claw@localhost:5432/student_claw

# ── Agnes AI (chat + embeddings, OpenAI-compatible endpoint) ────────────────
AGNES_AI_API_KEY=sk-
AGNES_AI_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_CHAT_MODEL=agnes-2.0-flash
AGNES_EMBED_MODEL=agnes-embeddings
EMBED_DIM=1536

# ── Qdrant (vector DB) ──────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Redis (job queue + SSE pub/sub) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO (S3-compatible file storage) ──────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# ── Telegram bot ────────────────────────────────────────────────────────────
# Token from @BotFather. Disable the bot's group-privacy mode so it can read
# group messages (BotFather → /setprivacy → Disable).
TELEGRAM_BOT_TOKEN=8968275072:AAHykIKSCWdVD_GdrNz3DBJ-1OMppVFVExM
TELEGRAM_BOT_USERNAME=sutdclaw_bot
# Webhook secret (any random string). Required even in polling mode.
TELEGRAM_WEBHOOK_SECRET=
# Production webhook only — leave EMPTY for local polling-mode development.
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_PATH=/bot/webhook

# ── Linkage key derivation (Telegram ↔ web) ─────────────────────────────────
PROJECT_KEY_HMAC_SECRET=5ffcae009bc8b0928b65fd25e9fc2a5df6b49e1cd082f072e48749ebdbebb69a

# ── Auth / JWT (SHARED with frontend) ───────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── At-rest encryption for Google refresh tokens (SHARED with frontend) ─────
# Exactly 32 bytes → 64 hex chars.  openssl rand -hex 32
ENCRYPTION_KEY=

# ── Google Calendar OAuth2 (SHARED client with frontend) ────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── CORS (optional; comma-separated origins for direct browser access) ──────
CORS_ORIGINS=http://localhost:3000
